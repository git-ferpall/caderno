# Impede execução de scripts na pasta de armazenamento do Silo
<IfModule mod_php.c>
    php_flag engine off
</IfModule>
<IfModule mod_php7.c>
    php_flag engine off
</IfModule>
<IfModule mod_php8.c>
    php_flag engine off
</IfModule>

Options -Indexes -ExecCGI
AddType text/plain .php .phtml .php3 .php4 .php5 .phar .html .htm .js .sh .exe .bat .cmd

<FilesMatch "\.(php|phtml|php3|php4|php5|php7|php8|phar|cgi|pl|py|sh|bash|exe|bat|cmd|com|msi|asp|aspx|jsp)$">
    Require all denied
</FilesMatch>
