<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Redireciona GET com .php para URL limpa (mantém APIs/backend com .php)
    RewriteCond %{REQUEST_METHOD} =GET
    RewriteCond %{REQUEST_URI} !^/(funcoes|configuracao|sso|scripts|vendor)/ [NC]
    RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?] [NC]
    RewriteRule ^ /%1 [R=301,L,NE]

    # Reescreve URL limpa para o arquivo .php correspondente
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.+?)/?$ $1.php [L]
</IfModule>

DirectoryIndex index.php index.html

<IfModule mod_headers.c>
    Header set Permissions-Policy "microphone=(self), camera=()"
</IfModule>
