<IfModule mod_setenvif.c>
    SetEnvIf X-Forwarded-Proto "^https$" HTTPS=on
    SetEnvIf X-Forwarded-Proto "^https$" REQUEST_SCHEME=https
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # HTTPS atrás de proxy (nginx, load balancer) — evita redirects http://
    RewriteCond %{HTTP:X-Forwarded-Proto} =https [OR]
    RewriteCond %{HTTPS} =on
    RewriteRule ^ - [E=HTTPS:on,E=REQUEST_SCHEME:https]

    # /home sem barra: reescreve internamente (evita 301 http://.../home/ no fetch)
    RewriteRule ^home$ home/index.php [L]

    # Redireciona GET com .php para URL limpa (mantém APIs/backend com .php)
    RewriteCond %{REQUEST_METHOD} =GET
    RewriteCond %{REQUEST_URI} !^/(funcoes|configuracao|sso|scripts|vendor)/ [NC]
    RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?] [NC]
    RewriteRule ^ /%1 [R=301,L,NE]

    # Reescreve URL limpa para o arquivo .php correspondente
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.+?)/?$ $1.php [L]
</IfModule>

DirectoryIndex index.php index.html

<IfModule mod_headers.c>
    Header set Permissions-Policy "microphone=(self), camera=()"
</IfModule>
